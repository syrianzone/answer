# Copy this file to .env and fill in the values.
#   cp .env.example .env
# .env is gitignored and is read by docker-compose (env_file + ${VARS}).

# Installation
# INSTALL_PORT here is the HOST port published by docker-compose (container is :80).
INSTALL_PORT=9080
# AUTO_INSTALL=true runs a headless install from the vars below on first boot,
# skipping the web installer. Set false to click through the UI installer instead.
AUTO_INSTALL=true

# Timezone (baked into the image + used at runtime)
TIMEZONE=Asia/Damascus

# Database
# For the bundled postgres service, keep DB_TYPE=postgres and DB_HOST=db
# (the compose service name). DB_PASSWORD is REQUIRED — compose will refuse
# to start without it. For SQLite instead, set DB_TYPE=sqlite3 + DB_FILE and
# remove the db service from docker-compose.yaml.
DB_TYPE=postgres
DB_USERNAME=answer
DB_PASSWORD=change-me-strong-password
DB_HOST=db:5432
DB_NAME=answer
DB_FILE=

# Site
LANGUAGE=ar-SY
SITE_NAME=Answer
SITE_URL=https://your-domain.example
CONTACT_EMAIL=admin@your-domain.example

# Admin (used only when AUTO_INSTALL=true)
ADMIN_NAME=admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_EMAIL=admin@your-domain.example

# Content
EXTERNAL_CONTENT_DISPLAY=ask_before_display

# Swagger
SWAGGER_HOST=
SWAGGER_ADDRESS_PORT=

# Server
SITE_ADDR=0.0.0.0:3000

# Logging
LOG_LEVEL=INFO
LOG_PATH=
